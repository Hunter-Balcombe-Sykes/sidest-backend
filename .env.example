APP_NAME=Laravel
APP_ENV=local
APP_KEY=EXAMPLE
APP_DEBUG=false
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database
# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single,nightwatch
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Nightwatch — observability. Slow-route / slow-query / slow-job alert
# thresholds are set in the Nightwatch dashboard, not here. The knobs below
# control what events are captured and shipped. See config/nightwatch.php.
NIGHTWATCH_TOKEN=your-nightwatch-token-here
# NIGHTWATCH_ENABLED=true
# NIGHTWATCH_DEPLOY=
# NIGHTWATCH_CAPTURE_EXCEPTION_SOURCE_CODE=true
# NIGHTWATCH_CAPTURE_REQUEST_PAYLOAD=false
# NIGHTWATCH_REDACT_PAYLOAD_FIELDS=_token,password,password_confirmation
# NIGHTWATCH_REDACT_HEADERS=Authorization,Cookie,Proxy-Authorization,X-XSRF-TOKEN
# Sampling rates (1.0 = all, 0.1 = 10%). Drop request rate first under load; keep exceptions at 1.0.
# NIGHTWATCH_REQUEST_SAMPLE_RATE=1.0
# NIGHTWATCH_COMMAND_SAMPLE_RATE=1.0
# NIGHTWATCH_EXCEPTION_SAMPLE_RATE=1.0
# NIGHTWATCH_SCHEDULED_TASK_SAMPLE_RATE=1.0
# Filtering — drop noisy event categories once volume is high.
# NIGHTWATCH_IGNORE_CACHE_EVENTS=false
# NIGHTWATCH_IGNORE_QUERIES=false
# NIGHTWATCH_IGNORE_MAIL=false
# NIGHTWATCH_IGNORE_NOTIFICATIONS=false
# NIGHTWATCH_IGNORE_OUTGOING_REQUESTS=false
# NIGHTWATCH_LOG_LEVEL=debug
# Ingest agent (Laravel Cloud runs the daemon locally).
# NIGHTWATCH_INGEST_URI=127.0.0.1:2407
# NIGHTWATCH_INGEST_TIMEOUT=0.5
# NIGHTWATCH_INGEST_CONNECTION_TIMEOUT=0.5
# NIGHTWATCH_INGEST_EVENT_BUFFER=500

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=failover
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0

# Separate cache vs sessions vs queues vs locks
REDIS_CACHE_DB=0
REDIS_SESSION_DB=1
REDIS_QUEUE_DB=2
REDIS_CACHE_LOCKS_DB=3

# igbinary serializer + LZ4 compression on the cache connection (~3× memory reduction).
# Enable only after: (1) confirming phpredis compiled with igbinary+LZ4 via phpinfo(),
# and (2) flushing the Redis cache on deploy (serializer change invalidates existing entries).
# Trigger: median cached payload > ~10KB or Redis memory > ~1GB.
REDIS_IGBINARY=false

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Media disk (Cloudflare R2 / Laravel Cloud Object Storage)
# All images AND videos (originals, variants, HLS segments, posters) go in this bucket.
MEDIA_DISK_KEY=
MEDIA_DISK_SECRET=
MEDIA_DISK_REGION=auto
MEDIA_DISK_BUCKET=sidest-media
MEDIA_DISK_URL=https://media.yourdomain.com
MEDIA_DISK_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
MEDIA_DISK_PATH_STYLE=false
PARTNA_MEDIA_DISK=media

VITE_APP_NAME="${APP_NAME}"

DB_CONNECTION=pgsql
DB_HOST=EXAMPLE
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=EXAMPLE
DB_SSLMODE=require
DB_SEARCH_PATH=public,core,analytics,billing,retail

SUPABASE_URL=EXAMPLE
SUPABASE_ANON_KEY=EXAMPLE
SUPABASE_JWKS_URL=EXAMPLE
SUPABASE_JWT_ISSUER=EXAMPLE
SUPABASE_JWT_AUD=authenticated
SUPABASE_JWKS_CACHE_SECONDS=3600
SUPABASE_JWKS_FAIL_CLOSED=false
SUPABASE_SERVICE_ROLE_KEY=

SOFT_DELETE_RETENTION_DAYS=30
PARTNA_THROTTLE_ENABLED=true
PARTNA_WAITLIST_ENABLED=false

# Launch feature flags — default false; flip on when feature is ready to ship
PARTNA_SMART_BOOKING_ENABLED=false
PARTNA_SQUARE_SYNC_ENABLED=false
PARTNA_FRESHA_SYNC_ENABLED=false
PARTNA_CAPTCHA_ENABLED=false

# Image upload limits
PARTNA_IMAGE_MAX_UPLOAD_KB=10240
PARTNA_GALLERY_IMAGE_MAX=5
PARTNA_CONTENT_IMAGE_MAX=5

# Image processing variants
PARTNA_IMAGE_TARGET_KB=500
PARTNA_IMAGE_QUALITY=92
PARTNA_IMAGE_MIN_QUALITY=60
PARTNA_IMAGE_MAXIMIZED_QUALITY=92

# Video uploads (set PARTNA_VIDEO_UPLOADS_ENABLED=true only after video workers are running)
PARTNA_VIDEO_UPLOADS_ENABLED=false
PARTNA_VIDEO_MAX_UPLOAD_KB=512000
PARTNA_VIDEO_MAX_DURATION_SECONDS=300
PARTNA_FFMPEG_BINARY=ffmpeg
PARTNA_FFPROBE_BINARY=ffprobe
PARTNA_VIDEO_QUEUE_CONNECTION=redis_video
PARTNA_VIDEO_QUEUE_NAME=videos
PARTNA_VIDEO_QUEUE_TIMEOUT=3600
PARTNA_VIDEO_QUEUE_RETRY_AFTER=3600
PARTNA_VIDEO_OPTIMIZED_RESOLUTION=1280x720
PARTNA_VIDEO_OPTIMIZED_BITRATE=2000
PARTNA_VIDEO_OPTIMIZED_AUDIO_BITRATE=128
PARTNA_VIDEO_MAXIMIZED_RESOLUTION=1920x1080
PARTNA_VIDEO_MAXIMIZED_BITRATE=5000
PARTNA_VIDEO_MAXIMIZED_AUDIO_BITRATE=192
PARTNA_STORE_CHECKOUT_SESSION_TTL_MINUTES=120
PARTNA_LEGAL_SITE_SCHEME=https

# Reconciler — Shopify orders backstop. Cron expression. Default daily at 3am UTC.
# During the first 60 days post-launch use '0 * * * *' (hourly).
PARTNA_RECONCILER_SCHEDULE="0 3 * * *"
PARTNA_LEGAL_DEFAULT_CONTACT_NAME="Customer Support"
PARTNA_LEGAL_DEFAULT_SUPPORT_EMAIL="support@sidest.co"
PARTNA_LEGAL_DEFAULT_SUPPORT_PHONE="N/A"

NOTIFICATIONS_EMAIL_ENABLED=false

SQUARE_APPLICATION_ID=
SQUARE_CLIENT_SECRET=
SQUARE_ENVIRONMENT=production
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_NOTIFICATION_URL=

# Fresha Integration
# Fill these in AFTER receiving Fresha Partner API access
FRESHA_CLIENT_ID=
FRESHA_CLIENT_SECRET=
FRESHA_ENVIRONMENT=production
FRESHA_WEBHOOK_SIGNATURE_KEY=
FRESHA_WEBHOOK_NOTIFICATION_URL=

# Shopify Integration
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_API_VERSION=2025-01
SHOPIFY_APP_SCOPES=read_orders,read_products,read_customers
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_FALLBACK_SECRET=
SHOPIFY_WEBHOOK_ORDERS_TOPIC=orders/paid
SHOPIFY_APP_HANDLE=side-st
SHOPIFY_THROTTLE_MAX=1000
SHOPIFY_THROTTLE_RESTORE_RATE=100
SHOPIFY_THROTTLE_DEFAULT_COST=10
SHOPIFY_THROTTLE_MAX_RETRIES=3
SHOPIFY_THROTTLE_MAX_WAIT_MS=5000
SHOPIFY_HTTP_TIMEOUT=20

# GDPR webhooks
GDPR_QUEUE=gdpr
GDPR_QUEUE_RETRY_AFTER=660
GDPR_REDACT_PLACEHOLDER_DOMAIN=gdpr.sidest.io
GDPR_EXPORT_RETENTION_DAYS=30

# Streaming platform API credentials (for live status polling)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# Sidest-Embedded Shopify app → backend shared key
PARTNA_EMBEDDED_API_KEY=

# Cloudflare DNS — used to provision platform subdomains (brand.sidest.co)
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# Cloudflare Turnstile — bot protection for public lead-capture endpoints.
# Obtain from Cloudflare Dashboard → Turnstile → your widget → secret key.
# Enable bot protection by also setting PARTNA_CAPTCHA_ENABLED=true.
# Frontend must send the Turnstile widget token in the cf_turnstile_response field.
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Hydrogen deployment — GitHub PAT with actions:write on sidest-storefront repo.
# Used to trigger single-brand Oxygen deployments when a brand saves credentials.
PARTNA_HYDROGEN_GITHUB_TOKEN=

# Shared key for internal Hydrogen API endpoints (brand-config, deployment-targets, etc.).
# Must match between backend (.env) and callers (CI workflow + Hydrogen Oxygen env).
HYDROGEN_API_KEY=
