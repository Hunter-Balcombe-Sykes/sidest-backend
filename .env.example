APP_NAME=Laravel
APP_ENV=local
APP_KEY=EXAMPLE
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database
# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production hardening: set these in production .env
# SESSION_SECURE_COOKIE=true
# SESSION_ENCRYPT=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0

# Separate cache vs sessions vs queues
REDIS_CACHE_DB=0
REDIS_SESSION_DB=1
REDIS_QUEUE_DB=2

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Media disk (Cloudflare R2 / Laravel Cloud Object Storage)
# All images AND videos (originals, variants, HLS segments, posters) go in this bucket.
MEDIA_DISK_KEY=
MEDIA_DISK_SECRET=
MEDIA_DISK_REGION=auto
MEDIA_DISK_BUCKET=comet-media
MEDIA_DISK_URL=https://media.yourdomain.com
MEDIA_DISK_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
MEDIA_DISK_PATH_STYLE=false
COMET_MEDIA_DISK=media

VITE_APP_NAME="${APP_NAME}"

DB_CONNECTION=pgsql
DB_HOST=EXAMPLE
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=EXAMPLE
DB_SSLMODE=require
DB_SEARCH_PATH=public,core,analytics,billing,retail

SUPABASE_URL=EXAMPLE
SUPABASE_ANON_KEY=EXAMPLE
SUPABASE_JWKS_URL=EXAMPLE
SUPABASE_JWT_ISSUER=EXAMPLE
SUPABASE_JWT_AUD=authenticated
SUPABASE_JWKS_CACHE_SECONDS=3600

SOFT_DELETE_RETENTION_DAYS=30
COMET_THROTTLE_ENABLED=true

# Image upload limits
COMET_IMAGE_MAX_UPLOAD_KB=10240
COMET_GALLERY_IMAGE_MAX=5
COMET_CONTENT_IMAGE_MAX=5

# Image processing variants
COMET_IMAGE_TARGET_KB=500
COMET_IMAGE_QUALITY=92
COMET_IMAGE_MIN_QUALITY=60
COMET_IMAGE_MAXIMIZED_QUALITY=100

# Video uploads (set COMET_VIDEO_UPLOADS_ENABLED=true only after video workers are running)
COMET_VIDEO_UPLOADS_ENABLED=false
COMET_VIDEO_MAX_UPLOAD_KB=512000
COMET_VIDEO_MAX_DURATION_SECONDS=300
COMET_FFMPEG_BINARY=ffmpeg
COMET_FFPROBE_BINARY=ffprobe
COMET_VIDEO_QUEUE_CONNECTION=redis_video
COMET_VIDEO_QUEUE_NAME=videos
COMET_VIDEO_QUEUE_TIMEOUT=3600
COMET_VIDEO_QUEUE_RETRY_AFTER=3600
COMET_VIDEO_OPTIMIZED_RESOLUTION=1280x720
COMET_VIDEO_OPTIMIZED_BITRATE=2000
COMET_VIDEO_OPTIMIZED_AUDIO_BITRATE=128
COMET_VIDEO_MAXIMIZED_RESOLUTION=1920x1080
COMET_VIDEO_MAXIMIZED_BITRATE=5000
COMET_VIDEO_MAXIMIZED_AUDIO_BITRATE=192
COMET_STORE_CHECKOUT_SESSION_TTL_MINUTES=120
COMET_LEGAL_SITE_SCHEME=https
COMET_LEGAL_DEFAULT_CONTACT_NAME="Customer Support"
COMET_LEGAL_DEFAULT_SUPPORT_EMAIL="support@comet.app"
COMET_LEGAL_DEFAULT_SUPPORT_PHONE="N/A"

SQUARE_APPLICATION_ID=
SQUARE_CLIENT_SECRET=
SQUARE_ENVIRONMENT=production
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_NOTIFICATION_URL=

# Fresha Integration
# Fill these in AFTER receiving Fresha Partner API access
FRESHA_CLIENT_ID=
FRESHA_CLIENT_SECRET=
FRESHA_ENVIRONMENT=production
FRESHA_WEBHOOK_SIGNATURE_KEY=
FRESHA_WEBHOOK_NOTIFICATION_URL=

# Shopify Integration
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_API_VERSION=2025-01
SHOPIFY_APP_SCOPES=read_orders,read_products,read_customers
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_FALLBACK_SECRET=
SHOPIFY_WEBHOOK_ORDERS_TOPIC=orders/paid
